# MongoDB configuration
# Use local connection for development or Atlas URI for production
MONGODB_URI=mongodb://localhost:27017/kazilink

# API server configuration
PORT=5000
FRONTEND_URL=http://localhost:3000

# JWT Authentication secret (Required)
# Use a strong random string (e.g., 'openssl rand -base64 32')
JWT_SECRET=your_jwt_secret_here

# Supabase configuration (Required)
# Found in Project Settings > API
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Security & Node Environment
NODE_ENV=development
